# Beispiel-Konfiguration für lokale Entwicklung.
# Echten Inhalt nach .env.local kopieren — .env.local ist gitignored.

# WordPress-GraphQL-Endpoint (Local by Flywheel)
WORDPRESS_API_URL=http://finanzleser.local/graphql

# Google Gemini API-Key für Leo-Chat (Phase: Prototyp / wird später durch Kunden-Tool ersetzt).
# Kostenloser Key auf https://aistudio.google.com → "Get API key".
# Free Tier: 15 req/min, 1500 req/Tag, 1 Mio Tokens/Tag.
GOOGLE_GENERATIVE_AI_API_KEY=
